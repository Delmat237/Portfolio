# Configuration email (formulaire de contact)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# Base de données PostgreSQL (Supabase, Neon, Vercel Postgres, etc.)
# Si le mot de passe contient des caractères spéciaux (@, #, /, :, etc.),
# encodez-les en URL : @ → %40, # → %23, / → %2F, : → %3A
# Exemple : mot de passe "Mon@Pass#2026" → Mon%40Pass%232026
#
# Supabase — connexion directe (db:push, db:seed en local) :
# DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_REF.supabase.co:5432/postgres?sslmode=require
#
# Supabase — pooler transactionnel (recommandé sur Vercel, port 6543) :
# DATABASE_URL=postgresql://postgres.VOTRE_REF:VOTRE_MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# Authentification admin (serveur uniquement — ne jamais préfixer par NEXT_PUBLIC_)
ADMIN_PASSWORD=change-me
# Optionnel : secret pour signer les sessions et autoriser les appels API (Bearer token)
ADMIN_API_SECRET=change-me-too

# Cloudinary (upload d'images via l'admin)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Supabase (optionnel — si vous utilisez le client Supabase côté client à l'avenir)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
